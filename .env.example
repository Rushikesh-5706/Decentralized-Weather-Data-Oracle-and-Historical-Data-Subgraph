# ── Wallet / Deployer ──────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=your_metamask_private_key_here
DEPLOYER_ADDRESS=0xYourWalletAddress

# ── Alchemy / RPC ──────────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key
NETWORK=sepolia

# ── Chainlink Configuration ────────────────────────────────────────────
CHAINLINK_LINK_TOKEN=0x779877A7B0D9E8603169DdbD7836e478b4624789
CHAINLINK_ORACLE_ADDRESS=0x6090149792dAAeE9D1D568c9f9a6F6B46AA29eFD
CHAINLINK_JOB_ID=fcf4140d696d44b687012232948bdd5d
CHAINLINK_FEE=100000000000000000

# ── Weather API ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/2.5/weather

# ── The Graph ──────────────────────────────────────────────────────────
GRAPH_ACCESS_TOKEN=your_graph_studio_deploy_key
GRAPH_ACCOUNT=your_graph_account
SUBGRAPH_NAME=weather-oracle-sepolia

# ── Frontend (React) ───────────────────────────────────────────────────
REACT_APP_CONTRACT_ADDRESS=0xYourDeployedContractAddress
REACT_APP_SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_ID/weather-oracle-sepolia/v1
REACT_APP_NETWORK_ID=11155111
REACT_APP_NETWORK_NAME=Sepolia

# ── Docker ─────────────────────────────────────────────────────────────
DOCKER_HUB_USERNAME=your_dockerhub_username
