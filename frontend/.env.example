# ── Wallet / Deployer ──────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=                    # MetaMask account private key (without 0x prefix)
DEPLOYER_ADDRESS=                        # MetaMask wallet address

# ── Alchemy / RPC ──────────────────────────────────────────────────────
ALCHEMY_API_KEY=                         # From alchemy.com dashboard
ALCHEMY_RPC_URL=                         # RPC URL endpoint

# ── Chainlink Configuration ────────────────────────────────────────────
CHAINLINK_LINK_TOKEN=                    # LINK token address on Sepolia: 0x779877A7B0D9E8603169DdbD7836e478b4624789
CHAINLINK_ORACLE_ADDRESS=                # Oracle contract on Sepolia
CHAINLINK_JOB_ID=                        # bytes32 Job ID from oracle provider
CHAINLINK_FEE=100000000000000000         # 0.1 LINK in wei

# ── Weather API ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=                  # From openweathermap.org (free tier)

# ── The Graph ──────────────────────────────────────────────────────────
GRAPH_ACCESS_TOKEN=                      # From thegraph.com dashboard
GRAPH_ACCOUNT=                           # Your Graph username/org slug

# ── Frontend (React) ───────────────────────────────────────────────────
REACT_APP_CONTRACT_ADDRESS=              # Deployed WeatherOracle contract address
REACT_APP_SUBGRAPH_URL=                  # The Graph subgraph endpoint url
REACT_APP_NETWORK_ID=11155111            # Sepolia chain ID
REACT_APP_NETWORK_NAME=Sepolia

# ── Docker ─────────────────────────────────────────────────────────────
DOCKER_HUB_USERNAME=rushi5706
